# The Odds API - get free key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Vercel KV - automatically provided when you connect KV in Vercel dashboard
# Do NOT set these manually - Vercel injects them automatically
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# A secret string used to protect the manual update trigger in admin panel
# Make up any random string, e.g. "bracket2026secret"
CRON_SECRET=your_secret_string_here

# Controls when the tournament lock kicks in
# Thursday March 19 2026 at 11 AM ET = Thursday March 19 15:00 UTC
TOURNAMENT_LOCK_TIME=2026-03-20T15:00:00Z

# Selection Sunday date - bracket won't show until after this
SELECTION_SUNDAY=2026-03-16T22:00:00Z

# LOCAL DEV ONLY: Set to true to use dummy Yahoo pick % data
# (before real brackets are filled out on Yahoo)
# Remove or set to false before deploying to production
USE_DUMMY_YAHOO=true

# LOCAL DEV: dummy flags for TeamRankings and Odds API
USE_DUMMY_TEAMRANKINGS=true
USE_DUMMY_ODDS=true
USE_DUMMY_KALSHI=true
KALSHI_API_KEY=your_kalshi_api_key_here
